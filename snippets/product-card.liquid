{% comment %}
  Gotham Knights "Clean Premium" product card.
  Ported from the ProductCard component of the Gotham Storefront design.

  Real product imagery is used when present; products without a photo fall back
  to a branded crest / halftone stand-in (as the design intends before launch).

  @param {product} product - the product to render (required)
  @param {string}  [label] - eyebrow label (defaults to product.type)
  @param {string}  [badge] - badge text override (auto-derived from tags otherwise)
  @param {boolean} [badge_navy] - navy badge instead of gold
  @param {boolean} [dark] - use the dark crest stand-in when no image (else derived)
{% endcomment %}

{% liquid
  assign card_label = label | default: product.type
  if card_label == blank
    assign card_label = product.vendor
  endif

  assign card_badge = badge
  if card_badge == blank
    comment
      Metafield-driven badge wins (merchant-set, no code); then tag-driven,
      matched case-insensitively so "best-seller", "Best-Seller", etc. all work.
    endcomment
    assign mf_badge = product.metafields.custom.badge.value | default: product.metafields.custom.badge
    if mf_badge != blank
      assign card_badge = mf_badge
    else
      assign tags_down = product.tags | join: '||' | downcase
      if tags_down contains 'best-seller'
        assign card_badge = 'Best-seller'
        assign badge_navy = true
      elsif tags_down contains 'new'
        assign card_badge = 'New'
      elsif tags_down contains 'limited'
        assign card_badge = 'Limited'
      elsif tags_down contains '25th anniversary'
        assign card_badge = '25th Anniversary'
      endif
    endif
  endif

  comment
    Alternate the stand-in tone deterministically when no image is set.
  endcomment
  assign is_dark = dark
  unless dark
    assign parity = product.id | modulo: 2
    if parity == 0
      assign is_dark = true
    else
      assign is_dark = false
    endif
  endunless

  assign color_option = null
  for opt in product.options_with_values
    assign opt_down = opt.name | downcase
    if opt_down == 'color' or opt_down == 'colour'
      assign color_option = opt
    endif
  endfor
%}

<div class="gk-pcard">
  <div class="gk-pcard-media">
    <a class="gk-pcard-imglink" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 600 | image_tag:
          loading: 'lazy', widths: '280,372,560,600', class: 'gk-pcard-img',
          alt: product.featured_image.alt | default: product.title | escape }}
      {% elsif is_dark %}
        <span class="gk-pcard-standin gk-standin-dark">
          {{ 'gk-shield-inv.svg' | inline_asset_content }}
        </span>
      {% else %}
        <span class="gk-pcard-standin gk-standin-light">
          {{ 'gk-shield-2c.svg' | inline_asset_content }}
        </span>
      {% endif %}
    </a>

    {% if card_badge != blank %}
      <span class="gk-badge {% if badge_navy %}gk-badge-navy{% else %}gk-badge-gold{% endif %}">{{ card_badge }}</span>
    {% endif %}

    {% comment %}
      Quick-add: single-variant products add straight to cart; multi-variant
      products open the PDP so the shopper picks a size/color instead of silently
      getting the first variant. Sold-out products show a disabled control.
    {% endcomment %}
    {% if product.available == false %}
      <div class="gk-qa-form">
        <button type="button" class="gk-qa" disabled aria-disabled="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
          Sold out
        </button>
      </div>
    {% elsif product.has_only_default_variant or product.variants.size == 1 %}
      {% form 'product', product, class: 'gk-qa-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="gk-qa">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
          Quick add
        </button>
      {% endform %}
    {% else %}
      <div class="gk-qa-form">
        <a href="{{ product.url }}" class="gk-qa" aria-label="Choose options for {{ product.title | escape }}">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
          Choose options
        </a>
      </div>
    {% endif %}
  </div>

  <a class="gk-pcard-body" href="{{ product.url }}">
    {% if card_label != blank %}<div class="gk-pcard-eyebrow">{{ card_label }}</div>{% endif %}
    <div class="gk-pcard-row">
      <h3 class="gk-pcard-title">{{ product.title }}</h3>
      <span class="gk-pcard-price">
        {%- if product.compare_at_price > product.price -%}
          <s class="gk-pcard-was">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        {{ product.price | money }}
      </span>
    </div>
    {%- if color_option -%}
    <div class="gk-pcard-swatches">
        {%- for value in color_option.values limit: 5 -%}
          {%- render 'swatch', value: value, mode: 'card' -%}
        {%- endfor -%}
    </div>
    {%- endif -%}
  </a>
</div>

{% comment %} Card + badge + swatch + stand-in styles live in gotham-ds.css (shared). {% endcomment %}
