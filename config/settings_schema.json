[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "header",
        "content": "Brand fonts (Gotham Knights)"
      },
      {
        "type": "paragraph",
        "content": "The theme ships with Hanken Grotesk for headings and body. Turn on the toggle below to replace it with a font from Shopify's library. The athletic display font (GothamHTF) and the wordmark (Harbour) stay bundled and are not editable here."
      },
      {
        "type": "checkbox",
        "id": "use_custom_fonts",
        "label": "Use custom heading & body fonts",
        "info": "When off, the bundled Hanken Grotesk is used.",
        "default": false
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "default": "work_sans_n7",
        "label": "Heading font"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "work_sans_n4",
        "label": "Body font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand palette (Gotham Knights)"
      },
      {
        "type": "paragraph",
        "content": "These three colors drive the whole storefront. Leave a swatch empty to fall back to the bundled Gotham default."
      },
      {
        "type": "color",
        "id": "brand_navy",
        "default": "#0D1D41",
        "label": "Brand navy",
        "info": "Primary brand color. Drives headings, dark bands and the crest."
      },
      {
        "type": "color",
        "id": "brand_gold",
        "default": "#FEC526",
        "label": "Gold",
        "info": "Accent color for buttons, badges and highlights."
      },
      {
        "type": "color",
        "id": "brand_paper",
        "default": "#FBF7EE",
        "label": "Paper",
        "info": "Warm off-white page background."
      },
      {
        "type": "header",
        "content": "Base colors"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FBF7EE",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#0D1D41",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
