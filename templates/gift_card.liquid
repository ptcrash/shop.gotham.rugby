{% comment %}
  Gotham Knights gift card — branded, print-ready card with the crest, balance,
  redemption code, optional expiry, Apple Wallet pass, and a print button.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/gift-card
{% endcomment %}
{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Gotham Knights design system (tokens, patterns, components) %}
    <link rel="preload" href="{{ 'gotham-harbour-bold.ttf' | asset_url }}" as="font" type="font/ttf" crossorigin>
    <link rel="preload" href="{{ 'gotham-black.otf' | asset_url }}" as="font" type="font/otf" crossorigin>
    {{ 'gotham-ds.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% style %}
      body { margin: 0; background: var(--paper); }
    {% endstyle %}

    {{ content_for_header }}
  </head>

  <body class="gk">
    {% liquid
      assign is_void = false
      if gift_card.enabled == false or gift_card.expired
        assign is_void = true
      endif
    %}

    <main class="gk-gc">
      <div class="gk-gc-card{% if is_void %} is-void{% endif %}">
        <div class="gk-gc-top">
          <span class="gk-gc-crest">{{ 'gk-shield-inv.svg' | inline_asset_content }}</span>
          <div class="gk-gc-brand">{{ shop.name }}</div>
          <div class="gk-eyebrow-gold gk-eyebrow-onnavy gk-gc-eyebrow">Gift card</div>
          <div class="gk-gc-balance">{{ gift_card.balance | money }}</div>
          {% if gift_card.balance != gift_card.initial_value %}
            <div class="gk-gc-initial">Initial value {{ gift_card.initial_value | money }}</div>
          {% endif %}
        </div>

        <div class="gk-gc-body">
          {% if is_void %}
            <p class="gk-gc-status">
              {% if gift_card.expired %}{{ 'gift_card.expired' | t }}{% else %}This gift card is no longer active.{% endif %}
            </p>
          {% endif %}

          {% if gift_card.expires_on and gift_card.expired == false %}
            {% assign expires_on = gift_card.expires_on | date: '%B %-d, %Y' %}
            <p class="gk-gc-expiry">{{ 'gift_card.expires_on' | t: expires_on: expires_on }}</p>
          {% endif %}

          <p class="gk-gc-note">{{ 'gift_card.use_at_checkout' | t }}</p>

          <div class="gk-gc-codewrap">
            <span class="gk-gc-code-label">Your code</span>
            <div class="gk-gc-code">{{ gift_card.code | format_code }}</div>
          </div>

          <div class="gk-gc-actions">
            <a href="{{ shop.url }}" class="gk-btn gk-btn-primary gk-gc-shop">Shop now</a>
            <button type="button" class="gk-btn gk-btn-invert gk-gc-print" onclick="window.print()">Print</button>
          </div>

          {% if gift_card.pass_url %}
            <a href="{{ gift_card.pass_url }}" class="gk-gc-wallet">
              <img
                src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
                alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
                width="200"
                height="60"
              >
            </a>
          {% endif %}
        </div>

        <hr class="gk-pride-rule gk-gc-rule">
        <p class="gk-gc-support">Your purchase supports Gotham Rugby — NYC's inclusive rugby club. (Not a tax-deductible donation.)</p>
      </div>
    </main>

    {% style %}
      .gk-gc { min-height: 100vh; display: grid; place-items: center; padding: 40px 20px; }
      .gk-gc-card { width: 100%; max-width: 460px; background: #fff; border: 1px solid var(--border); border-radius: 18px; overflow: hidden; box-shadow: 0 24px 60px rgba(7,17,42,.16); }
      .gk-gc-card.is-void { opacity: .72; }

      .gk-gc-top { position: relative; background: var(--navy-700); color: #fff; padding: 34px 30px 30px; text-align: center; overflow: hidden; }
      .gk-gc-crest { position: absolute; top: 50%; right: -12%; transform: translateY(-50%); width: 150px; opacity: .1; }
      .gk-gc-crest svg { width: 100%; height: auto; }
      .gk-gc-brand { position: relative; font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .16em; color: var(--navy-100); margin-bottom: 14px; }
      .gk-gc-eyebrow { position: relative; margin-bottom: 6px; }
      .gk-gc-balance { position: relative; font: 700 3.2rem/1 var(--font-mono); color: var(--gold-500); }
      .gk-gc-initial { position: relative; font: 500 12px var(--font-mono); color: var(--navy-200); margin-top: 6px; }

      .gk-gc-body { padding: 26px 30px 24px; text-align: center; }
      .gk-gc-status { font: 700 14px var(--font-body); color: #b3261e; margin: 0 0 14px; }
      .gk-gc-expiry { font: 600 13px var(--font-mono); color: var(--ink-500); margin: 0 0 10px; }
      .gk-gc-note { font: 400 14px/1.5 var(--font-body); color: var(--ink-700); margin: 0 0 18px; }

      .gk-gc-codewrap { border: 2px dashed var(--border-strong); border-radius: 12px; padding: 16px; margin-bottom: 22px; }
      .gk-gc-code-label { display: block; font: 700 10px var(--font-body); text-transform: uppercase; letter-spacing: .12em; color: var(--ink-500); margin-bottom: 8px; }
      .gk-gc-code { font: 700 1.5rem var(--font-mono); letter-spacing: .12em; color: var(--navy-700); word-break: break-all; }

      .gk-gc-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 18px; }
      .gk-gc-shop, .gk-gc-print { font-size: 13px; padding: 13px 22px; }
      .gk-gc-wallet { display: inline-block; }
      .gk-gc-wallet img { display: block; }

      .gk-gc-rule { width: 90px; margin: 6px auto 16px; }
      .gk-gc-support { font: 500 11.5px/1.5 var(--font-body); color: var(--ink-500); text-align: center; padding: 0 30px 26px; margin: 0; }

      @media print {
        body { background: #fff; }
        .gk-gc-actions, .gk-gc-wallet { display: none !important; }
        .gk-gc-card { box-shadow: none; border: 1px solid #ccc; }
      }
      @media (max-width: 480px) {
        .gk-gc-balance { font-size: 2.6rem; }
        .gk-gc-code { font-size: 1.2rem; }
      }
    {% endstyle %}
  </body>
</html>
