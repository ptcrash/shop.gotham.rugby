/* ============================================================
   Gotham Knights — Design System (theme build)
   Consolidated from the claude.ai/design Gotham Knights system:
   fonts + colors + typography + spacing + base + patterns,
   plus the storefront component/interaction layer.
   Font + logo URLs are resolved through the Shopify asset pipeline.
   ============================================================ */

@import url("https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Spline+Sans+Mono:wght@400;500;600&display=swap");

/* --- Webfonts --- */
@font-face {
  font-family: "Harbour";
  src: url("{{ 'gotham-harbour-bold.ttf' | asset_url }}") format("truetype");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "GothamHTF";
  src: url("{{ 'gotham-black.otf' | asset_url }}") format("opentype");
  font-weight: 900;
  font-style: normal;
  font-display: swap;
}

:root {
  /* --- Brand core --- */
  --navy-900: #07112a;
  --navy-800: #0a1736;
  --navy-700: #0d1d41;
  --navy-600: #142a5c;
  --navy-500: #1d3a78;
  --navy-400: #2f5099;
  --navy-300: #6680b8;
  --navy-200: #aab9d6;
  --navy-100: #d9e0ef;

  --gold-700: #b8810a;
  --gold-600: #d99e12;
  --gold-500: #fec526;
  --gold-400: #ffd45c;
  --gold-300: #ffe293;
  --gold-200: #fff0c9;
  --gold-100: #fff8e8;

  --paper: #fbf7ee;
  --paper-2: #f3ecdc;
  --white: #ffffff;
  --ink-900: #11151f;
  --ink-700: #353b49;
  --ink-500: #5d6473;
  --ink-400: #868d9c;
  --ink-300: #b6bcc8;
  --ink-200: #dde0e7;
  --ink-100: #eef0f4;

  --pride-red: #e4453a;
  --pride-orange: #f08a24;
  --pride-yellow: #fec526;
  --pride-green: #2faa6a;
  --pride-blue: #2f74d0;
  --pride-violet: #8b46c9;

  --success: #2faa6a;
  --danger: #d83a3a;

  /* Semantic aliases (light theme) */
  --surface-page: var(--paper);
  --surface-card: var(--white);
  --surface-brand: var(--navy-700);
  --text-strong: var(--navy-700);
  --text-body: var(--ink-700);
  --text-muted: var(--ink-500);
  --accent: var(--gold-500);
  --border: var(--ink-200);
  --border-strong: var(--ink-300);
  --focus-ring: var(--gold-500);

  /* Families */
  --font-wordmark: "Harbour", Georgia, serif;
  --font-heading: "Hanken Grotesk", system-ui, -apple-system, "Segoe UI", sans-serif;
  --font-athletic: "GothamHTF", "Arial Black", "Hanken Grotesk", system-ui, sans-serif;
  --font-body: "Hanken Grotesk", system-ui, -apple-system, "Segoe UI", sans-serif;
  --font-mono: "Spline Sans Mono", ui-monospace, "SF Mono", Menlo, monospace;

  /* Weights */
  --fw-regular: 400; --fw-medium: 500; --fw-semibold: 600;
  --fw-bold: 700; --fw-extrabold: 800; --fw-black: 900;

  /* Letter spacing */
  --ls-tight: -0.01em;
  --ls-overline: 0.16em;
  --tracking-wordmark: -0.05em;

  /* Spacing */
  --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem;
  --space-5: 1.5rem; --space-6: 2rem; --space-7: 3rem; --space-8: 4rem;
  --space-9: 6rem; --space-10: 8rem;

  /* Radius */
  --radius-xs: 3px; --radius-sm: 6px; --radius-md: 10px;
  --radius-lg: 16px; --radius-xl: 24px; --radius-pill: 999px;

  /* Border widths */
  --bw-hairline: 1px; --bw-base: 2px; --bw-bold: 3px;

  /* Shadows */
  --shadow-sm: 0 2px 6px rgba(7, 17, 42, 0.10);
  --shadow-md: 0 6px 18px rgba(7, 17, 42, 0.12);
  --shadow-lg: 0 16px 40px rgba(7, 17, 42, 0.18);

  /* Focus */
  --focus-width: 3px;
  --focus-offset: 2px;

  /* Layout */
  --gk-content-width: 1180px;

  /* Motion */
  --ease-standard: cubic-bezier(0.2, 0, 0, 1);
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --dur-fast: 120ms; --dur-base: 200ms; --dur-slow: 320ms;
}

/* ============================================================
   Base
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; }

body.gk {
  font-family: var(--font-body);
  background: var(--paper);
  color: var(--text-body);
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

.gk :where(h1, h2, h3, h4) {
  font-family: var(--font-heading);
  color: var(--text-strong);
  line-height: 1.18;
  letter-spacing: var(--ls-tight);
  font-weight: var(--fw-extrabold);
  margin: 0;
}
.gk ::selection { background: var(--gold-500); color: var(--navy-700); }
.gk a { color: inherit; }

/* Brand utilities */
.gk-athletic {
  font-family: var(--font-athletic);
  font-weight: var(--fw-black);
  text-transform: uppercase;
  line-height: 0.95;
  letter-spacing: var(--ls-tight);
}
.gk-overline {
  font-family: var(--font-body);
  font-weight: var(--fw-bold);
  text-transform: uppercase;
  letter-spacing: var(--ls-overline);
  font-size: 0.6875rem;
}
.gk-pride-rule {
  height: 4px; border: 0; border-radius: var(--radius-pill);
  background: linear-gradient(90deg,
    var(--pride-red) 0 16.66%, var(--pride-orange) 16.66% 33.33%,
    var(--pride-yellow) 33.33% 50%, var(--pride-green) 50% 66.66%,
    var(--pride-blue) 66.66% 83.33%, var(--pride-violet) 83.33% 100%);
}

/* ============================================================
   Pattern utilities
   ============================================================ */
.gk-checker {
  background:
    conic-gradient(var(--navy-700) 0 25%, var(--gold-500) 0 50%,
      var(--navy-700) 0 75%, var(--gold-500) 0)
    0 0 / var(--gk-checker-size, 30px) var(--gk-checker-size, 30px);
}
.gk-stripes {
  background: repeating-linear-gradient(-45deg,
    var(--navy-700) 0 var(--gk-stripe-size, 26px),
    var(--gold-500) var(--gk-stripe-size, 26px) calc(var(--gk-stripe-size, 26px) * 2));
}
.gk-halftone-duotone {
  background-color: var(--navy-700);
  background-image:
    linear-gradient(105deg, transparent 10%, var(--navy-700) 86%),
    radial-gradient(var(--gold-500) 1.7px, transparent 1.9px);
  background-size: 100% 100%, 12px 12px;
}
.gk-halftone-fade {
  background-color: var(--paper);
  background-image:
    linear-gradient(105deg, transparent 16%, var(--paper) 92%),
    radial-gradient(var(--navy-700) 1.6px, transparent 1.8px);
  background-size: 100% 100%, 11px 11px;
}

/* ============================================================
   Component / interaction layer (from the storefront board)
   ============================================================ */
.gk-btn-primary {
  transition: transform var(--dur-fast) var(--ease-standard),
    background var(--dur-fast) var(--ease-standard), border-color var(--dur-fast);
}
.gk-btn-primary:hover { transform: translateY(-1px); background: var(--gold-400) !important; border-color: var(--gold-400) !important; }
.gk-btn-outline-light:hover { background: rgba(255,255,255,.12) !important; }
.gk-btn-invert:hover { background: var(--navy-600) !important; color: #fff !important; border-color: var(--navy-600) !important; }

.gk-ctile { transition: transform var(--dur-slow) var(--ease-standard), box-shadow var(--dur-slow) var(--ease-standard); }
.gk-ctile:hover { transform: translateY(-4px); box-shadow: 0 18px 44px rgba(7,17,42,.24); }
.gk-ctile:hover .gk-ctile-img { transform: scale(1.06); }
.gk-ctile-img { transition: transform .5s var(--ease-standard); }

.gk-navlink:hover { color: var(--gold-500) !important; }
.gk-tlink:hover { color: var(--navy-700) !important; }
.gk-iconbtn:hover { background: rgba(255,255,255,.12) !important; }
.gk-flink:hover { color: #fff !important; }
.gk-thumb { transition: transform .2s var(--ease-standard); }
.gk-thumb:hover { transform: scale(1.04); }

/* Product card (Clean Premium) */
.gk-pcard { transition: transform .22s var(--ease-standard), box-shadow .22s var(--ease-standard); }
.gk-pcard:hover { transform: translateY(-5px); box-shadow: 0 18px 40px rgba(7,17,42,.2); }
.gk-pcard .gk-qa { transform: translateY(103%); transition: transform .26s var(--ease-standard); }
.gk-pcard:hover .gk-qa { transform: translateY(0); }
.gk-pcard:focus-visible { outline: 3px solid var(--gold-500); outline-offset: 2px; }

@media (prefers-reduced-motion: reduce) {
  .gk * { transition: none !important; }
}

/* ============================================================
   Shared layout + component layer (used across sections)
   ============================================================ */

/* Content bands */
.gk-band { padding: 64px 50px; }
.gk-band-paper { background: var(--paper); }
.gk-band-sunken { background: var(--paper-2); }
.gk-band-inner { max-width: var(--gk-content-width); margin: 0 auto; }
.gk-band-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 20px; margin-bottom: 26px; flex-wrap: wrap; }
.gk-band-title { margin: 0; font: 800 30px var(--font-heading); color: var(--navy-700); letter-spacing: -.01em; }
.gk-eyebrow-gold { font: 700 11px var(--font-body); text-transform: uppercase; letter-spacing: .16em; color: var(--gold-700); margin-bottom: 10px; }
.gk-eyebrow-onnavy { color: var(--gold-400); }

/* Product grid */
.gk-pgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }

/* Buttons */
.gk-btn {
  display: inline-flex; align-items: center; gap: 10px; font: 700 16px var(--font-body);
  text-transform: uppercase; letter-spacing: .04em; line-height: 1; padding: 16px 30px;
  border-radius: 6px; text-decoration: none; cursor: pointer; border: 2px solid transparent;
}
.gk-btn-primary { background: var(--gold-500); border-color: var(--gold-500); color: var(--navy-700); }
.gk-btn-primary:hover { transform: translateY(-1px); background: var(--gold-400); border-color: var(--gold-400); }
.gk-btn-outline-light { background: transparent; border-color: rgba(255,255,255,.5); color: #fff; }
.gk-btn-outline-light:hover { background: rgba(255,255,255,.12); }
.gk-btn-invert { background: transparent; border: 2px solid var(--navy-700); color: var(--navy-700); font-size: 14px; padding: 14px 32px; }
.gk-btn-invert:hover { background: var(--navy-600); color: #fff; border-color: var(--navy-600); }

/* Text link with gold underline */
.gk-tlink {
  font: 700 13px var(--font-body); text-transform: uppercase; letter-spacing: .06em;
  color: var(--navy-500); text-decoration: none; border-bottom: 2px solid var(--gold-500);
  padding-bottom: 3px; white-space: nowrap; transition: color var(--dur-fast) var(--ease-standard);
}
.gk-tlink:hover { color: var(--navy-700); }

/* Badges */
.gk-badge {
  position: absolute; top: 12px; left: 12px; display: inline-flex; align-items: center;
  font: 700 10px var(--font-body); text-transform: uppercase; letter-spacing: .08em;
  padding: 5px 8px; border-radius: 3px;
}
.gk-badge-gold { color: var(--navy-700); background: var(--gold-500); }
.gk-badge-navy { color: #fff; background: var(--navy-700); }

/* Swatches (shared by card + PDP) */
.gk-swatch { width: 14px; height: 14px; border-radius: 99px; box-shadow: inset 0 0 0 1px rgba(0,0,0,.15); }

/* Crest stand-ins (shared by card, placeholder, PDP) */
.gk-pcard-standin { display: grid; place-items: center; width: 100%; aspect-ratio: 4/5; }
.gk-pcard-standin svg { width: 50%; height: auto; }
.gk-standin-light {
  background-color: var(--paper);
  background-image: linear-gradient(105deg, transparent 16%, var(--paper) 92%), radial-gradient(var(--navy-700) 1.6px, transparent 1.8px);
  background-size: 100% 100%, 11px 11px;
}
.gk-standin-light svg { width: 52%; filter: drop-shadow(0 10px 22px rgba(7,17,42,.16)); }
.gk-standin-dark {
  background-color: var(--navy-700);
  background-image: linear-gradient(105deg, transparent 8%, var(--navy-700) 82%), radial-gradient(var(--gold-500) 1.7px, transparent 1.9px);
  background-size: 100% 100%, 12px 12px;
}
.gk-standin-dark svg { width: 47%; opacity: .94; filter: drop-shadow(0 8px 18px rgba(0,0,0,.32)); }

/* Product card (Clean Premium) — shared by grid sections + PDP related */
.gk-pcard {
  position: relative; display: flex; flex-direction: column;
  background: #fff; border: 1px solid rgba(13,29,65,.12);
  border-radius: 12px; overflow: hidden; color: inherit;
  transition: transform .22s var(--ease-standard), box-shadow .22s var(--ease-standard);
}
.gk-pcard:hover { transform: translateY(-5px); box-shadow: 0 18px 40px rgba(7,17,42,.2); }
.gk-pcard-media { position: relative; overflow: hidden; }
.gk-pcard-imglink { display: block; }
.gk-pcard-img { display: block; width: 100%; aspect-ratio: 4/5; object-fit: cover; transition: transform .4s var(--ease-standard); }
.gk-pcard:hover .gk-pcard-img { transform: scale(1.04); }
.gk-qa-form { margin: 0; position: absolute; left: 0; right: 0; bottom: 0; }
.gk-qa {
  width: 100%; background: rgba(13,29,65,.95); color: #fff; padding: 13px; border: 0;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .1em; cursor: pointer;
  transform: translateY(103%); transition: transform .26s var(--ease-standard);
}
.gk-pcard:hover .gk-qa, .gk-qa:focus-visible { transform: translateY(0); }
.gk-qa[disabled] { cursor: not-allowed; opacity: .85; }
.gk-pcard-body { display: block; padding: 15px 16px 17px; text-decoration: none; color: inherit; }
.gk-pcard-eyebrow { font: 600 11px var(--font-mono); letter-spacing: .12em; text-transform: uppercase; color: var(--ink-500); }
.gk-pcard-row { display: flex; justify-content: space-between; gap: 10px; align-items: baseline; margin-top: 6px; }
.gk-pcard-title { margin: 0; font: 700 15px var(--font-heading); color: var(--navy-700); }
.gk-pcard-price { font: 600 14px var(--font-mono); color: var(--navy-700); white-space: nowrap; }
.gk-pcard-was { color: var(--ink-400); margin-right: 6px; }
.gk-pcard-swatches { display: flex; gap: 6px; margin-top: 11px; }

/* Collection tiles (shared by homepage collection-list + collections index) */
.gk-tiles { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.gk-ctile {
  position: relative; display: block; height: 300px; border-radius: 12px; overflow: hidden;
  text-decoration: none; border: 1px solid rgba(13,29,65,.12);
}
.gk-ctile-img { position: absolute; inset: 0; display: grid; place-items: center; overflow: hidden; }
.gk-ctile-img img:not(.gk-ctile-photo) { width: 46%; height: auto; }
.gk-ctile-photo { width: 100%; height: 100%; object-fit: cover; }
.gk-tile-photo .gk-ctile-img { background: var(--navy-700); }
.gk-tile-dark .gk-ctile-img { background-color: var(--navy-700); background-image: radial-gradient(var(--gold-500) 1.6px, transparent 1.8px); background-size: 12px 12px; }
.gk-tile-dark .gk-ctile-img img { opacity: .9; }
.gk-tile-light .gk-ctile-img { background-color: var(--paper); background-image: radial-gradient(var(--navy-700) 1.5px, transparent 1.7px); background-size: 11px 11px; }
.gk-tile-light .gk-ctile-img img { width: 48%; }
.gk-tile-stripes .gk-ctile-img { background: var(--navy-600); }
.gk-tile-stripes .gk-ctile-img::before { content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 30%; background: repeating-linear-gradient(-45deg, var(--navy-700) 0 13px, var(--gold-500) 13px 26px); opacity: .9; }
.gk-tile-stripes .gk-ctile-img img { position: relative; width: 42%; opacity: .92; margin-bottom: 26px; }
.gk-tile-anniversary .gk-ctile-img { background-color: var(--navy-700); background-image: linear-gradient(105deg, transparent 8%, var(--navy-700) 82%), radial-gradient(rgba(255,255,255,.05) 1.5px, transparent 1.7px); background-size: 100% 100%, 12px 12px; }
.gk-anniv { display: flex; flex-direction: column; align-items: center; }
.gk-anniv-num { font-family: var(--font-athletic); font-weight: 900; color: var(--gold-500); font-size: 5rem; line-height: .8; }
.gk-anniv-word { font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .3em; color: var(--gold-300); margin-top: 6px; }
.gk-ctile-scrim { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(7,17,42,.82), rgba(7,17,42,.1) 58%, transparent); }
.gk-tile-light .gk-ctile-scrim { background: linear-gradient(0deg, rgba(251,247,238,.96), rgba(251,247,238,.2) 52%, transparent); }
.gk-ctile-content { position: absolute; left: 18px; right: 18px; bottom: 16px; color: #fff; display: block; }
.gk-tile-light .gk-ctile-content { color: var(--navy-700); }
.gk-ctile-title { display: block; font: 800 20px var(--font-heading); letter-spacing: -.01em; }
.gk-ctile-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 5px; color: var(--gold-400); }
.gk-tile-light .gk-ctile-meta { color: var(--navy-600); }
.gk-ctile-count { font: 600 11px var(--font-mono); letter-spacing: .08em; text-transform: uppercase; white-space: nowrap; }
.gk-tile-light .gk-ctile-count { color: var(--ink-500); }

@media (max-width: 860px) {
  .gk-band { padding: 38px 18px; }
  .gk-pgrid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .gk-tiles { grid-template-columns: 1fr 1fr; gap: 12px; }
  .gk-ctile { height: 170px; }
  .gk-ctile-title { font-size: 15px; }
  .gk-anniv-num { font-size: 3.2rem; }
}
