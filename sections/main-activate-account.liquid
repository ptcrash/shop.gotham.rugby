{% comment %}
  Gotham Knights — activate account (classic customer accounts).
  Sets a password from an activation invite; can also decline the invite.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/customers-activate-account
{% endcomment %}

<div class="gk-acct gk-auth">
  <div class="gk-acct-hero full-width">
    <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-acct-hero-crest">
    <div class="gk-band-inner gk-acct-hero-inner">
      <nav class="gk-acct-crumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> /
        <span>{{ section.settings.heading | default: 'Activate account' }}</span>
      </nav>
      <h1 class="gk-acct-title gk-athletic">{{ section.settings.heading | default: 'Activate account' }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="gk-acct-sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>

  <div class="gk-band gk-band-paper full-width">
    <div class="gk-band-inner">
      <div class="gk-authwrap">
        {% form 'activate_customer_password', novalidate: 'novalidate' %}
          {% if form.errors %}
            <div class="gk-form-errors" role="alert" tabindex="-1">
              <ul>
                {% for field in form.errors %}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="gk-field">
            <label for="gk-activate-password">Password</label>
            <input type="password" name="customer[password]" id="gk-activate-password" class="gk-input" autocomplete="new-password" required>
          </div>
          <div class="gk-field">
            <label for="gk-activate-confirm">Confirm password</label>
            <input type="password" name="customer[password_confirmation]" id="gk-activate-confirm" class="gk-input" autocomplete="new-password" required>
          </div>

          <button type="submit" class="gk-btn gk-btn-primary gk-auth-submit">{{ section.settings.submit_label | default: 'Activate account' }}</button>
          <button type="submit" name="decline" class="gk-auth-decline">{{ section.settings.decline_label | default: 'Decline invitation' }}</button>
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .gk-acct-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 40px 50px 44px; }
  .gk-acct-hero-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-acct-hero-inner { position: relative; }
  .gk-acct-crumb { font: 600 12px var(--font-mono); letter-spacing: .04em; color: var(--navy-300); margin-bottom: 16px; }
  .gk-acct-crumb a { color: var(--navy-200); text-decoration: none; }
  .gk-acct-crumb span { color: var(--gold-400); }
  .gk-acct-title { color: #fff; font-size: 3rem; line-height: .95; margin: 0; }
  .gk-acct-sub { color: var(--navy-100); font-size: 1.05rem; line-height: 1.55; max-width: 60ch; margin: 14px 0 0; }

  .gk-authwrap { max-width: 460px; margin: 0 auto; }
  .gk-field { margin-bottom: 18px; }
  .gk-field label { display: block; font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .06em; color: var(--navy-700); margin-bottom: 8px; }
  .gk-input { width: 100%; padding: 13px 14px; border: 1.5px solid var(--border-strong); border-radius: 8px; font: 400 15px var(--font-body); color: var(--ink-900); background: #fff; }
  .gk-input:focus { outline: none; border-color: var(--navy-700); box-shadow: 0 0 0 3px rgba(13,29,65,.12); }

  .gk-auth-submit { width: 100%; justify-content: center; margin-top: 4px; }
  .gk-auth-decline { display: block; width: 100%; margin-top: 14px; padding: 12px; background: transparent; border: 0; font: 600 13px var(--font-body); color: var(--ink-500); text-decoration: underline; cursor: pointer; }
  .gk-auth-decline:hover { color: var(--danger); }

  .gk-form-errors { background: rgba(228,69,58,.08); border: 1px solid var(--danger); border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; }
  .gk-form-errors ul { margin: 0; padding-left: 18px; }
  .gk-form-errors li { font: 500 13.5px/1.5 var(--font-body); color: var(--danger); }

  @media (max-width: 860px) {
    .gk-acct-hero { padding: 26px 18px 30px; }
    .gk-acct-title { font-size: 2.1rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer activate account",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Activate account" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Create a password to activate your Gotham Knights account." },
    { "type": "text", "id": "submit_label", "label": "Submit button", "default": "Activate account" },
    { "type": "text", "id": "decline_label", "label": "Decline button", "default": "Decline invitation" }
  ],
  "presets": [{ "name": "Customer activate account" }],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
