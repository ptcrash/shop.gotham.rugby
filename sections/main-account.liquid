{% comment %}
  Gotham Knights — account overview (classic customer accounts).
  Welcome, order history, and links to addresses / logout.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/customers-account
{% endcomment %}

<div class="gk-acct">
  <div class="gk-acct-hero full-width">
    <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-acct-hero-crest">
    <div class="gk-band-inner gk-acct-hero-inner">
      <nav class="gk-acct-crumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> /
        <span>My account</span>
      </nav>
      <h1 class="gk-acct-title gk-athletic">
        {%- if customer.first_name != blank -%}
          {{ section.settings.greeting | default: 'Welcome back' }}, {{ customer.first_name }}
        {%- else -%}
          {{ section.settings.greeting | default: 'Welcome back' }}
        {%- endif -%}
      </h1>
      <p class="gk-acct-sub">{{ customer.email }}</p>
    </div>
  </div>

  <div class="gk-band gk-band-paper full-width">
    <div class="gk-band-inner gk-acct-body">
      <div class="gk-acct-layout">

        {% comment %} ---- Side panel ---- {% endcomment %}
        <aside class="gk-acct-side">
          <div class="gk-acct-card">
            <h2 class="gk-acct-card-title">Account</h2>
            <nav class="gk-acct-nav" aria-label="Account">
              <a class="gk-acct-nav-link" href="{{ routes.account_addresses_url }}">
                {% render 'gk-icon', name: 'ship' %}
                <span>Addresses{% if customer.addresses_count > 0 %} ({{ customer.addresses_count }}){% endif %}</span>
              </a>
              <a class="gk-acct-nav-link" href="{{ routes.account_logout_url }}">
                {% render 'gk-icon', name: 'secure' %}
                <span>Log out</span>
              </a>
            </nav>
          </div>
          {% if section.settings.support_note != blank %}
            <p class="gk-acct-support">{{ section.settings.support_note }}</p>
          {% endif %}
        </aside>

        {% comment %} ---- Order history ---- {% endcomment %}
        <div class="gk-acct-main">
          <h2 class="gk-acct-section-title">Order history</h2>

          {% paginate customer.orders by 20 %}
            {% if customer.orders.size > 0 %}
              <div class="gk-orders-scroll">
                <table class="gk-orders">
                  <thead>
                    <tr>
                      <th scope="col">Order</th>
                      <th scope="col">Date</th>
                      <th scope="col">Payment</th>
                      <th scope="col">Fulfillment</th>
                      <th scope="col" class="gk-orders-total">Total</th>
                      <th scope="col"><span class="gk-visually-hidden">View</span></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for order in customer.orders %}
                      <tr>
                        <th scope="row" data-label="Order">
                          <a class="gk-tlink" href="{{ order.customer_url }}">{{ order.name }}</a>
                        </th>
                        <td data-label="Date">{{ order.created_at | date: '%b %-d, %Y' }}</td>
                        <td data-label="Payment">
                          <span class="gk-status gk-status-{{ order.financial_status }}">{{ order.financial_status_label }}</span>
                        </td>
                        <td data-label="Fulfillment">
                          <span class="gk-status gk-status-{{ order.fulfillment_status }}">{{ order.fulfillment_status_label }}</span>
                        </td>
                        <td data-label="Total" class="gk-orders-total">{{ order.total_net_amount | money }}</td>
                        <td class="gk-orders-view"><a class="gk-tlink" href="{{ order.customer_url }}">View →</a></td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>

              {% if paginate.pages > 1 %}
                <nav class="gk-pagination" aria-label="Order history pages">
                  {% if paginate.previous %}<a class="gk-tlink" href="{{ paginate.previous.url }}">← Newer</a>{% endif %}
                  <span class="gk-pagination-count">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
                  {% if paginate.next %}<a class="gk-tlink" href="{{ paginate.next.url }}">Older →</a>{% endif %}
                </nav>
              {% endif %}
            {% else %}
              <div class="gk-acct-empty">
                <p class="gk-acct-empty-text">{{ section.settings.empty_text | default: "You haven't placed any orders yet." }}</p>
                <a class="gk-btn gk-btn-primary" href="{{ routes.all_products_collection_url }}">{{ section.settings.empty_button | default: 'Shop the drop' }}</a>
              </div>
            {% endif %}
          {% endpaginate %}
        </div>

      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .gk-acct-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 40px 50px 44px; }
  .gk-acct-hero-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-acct-hero-inner { position: relative; }
  .gk-acct-crumb { font: 600 12px var(--font-mono); letter-spacing: .04em; color: var(--navy-300); margin-bottom: 16px; }
  .gk-acct-crumb a { color: var(--navy-200); text-decoration: none; }
  .gk-acct-crumb span { color: var(--gold-400); }
  .gk-acct-title { color: #fff; font-size: 2.7rem; line-height: .98; margin: 0; }
  .gk-acct-sub { color: var(--navy-100); font: 500 14px var(--font-mono); margin: 14px 0 0; }

  .gk-acct-layout { display: grid; grid-template-columns: 260px 1fr; gap: 40px; align-items: start; }
  .gk-acct-card { background: var(--surface-card); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
  .gk-acct-card-title { font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .08em; color: var(--ink-500); margin: 0 0 14px; }
  .gk-acct-nav { display: flex; flex-direction: column; gap: 4px; }
  .gk-acct-nav-link { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: 8px; text-decoration: none; font: 600 14.5px var(--font-body); color: var(--navy-700); }
  .gk-acct-nav-link:hover { background: var(--paper-2); }
  .gk-acct-nav-link svg { color: var(--navy-600); flex: none; }
  .gk-acct-support { font: 500 13px/1.55 var(--font-body); color: var(--ink-500); margin: 18px 4px 0; }

  .gk-acct-section-title { font: 800 1.5rem var(--font-heading); color: var(--navy-700); margin: 0 0 20px; }
  .gk-orders-scroll { overflow-x: auto; border: 1px solid var(--border); border-radius: 12px; }
  .gk-orders { width: 100%; border-collapse: collapse; min-width: 560px; }
  .gk-orders thead th { text-align: left; font: 700 11px var(--font-body); text-transform: uppercase; letter-spacing: .06em; color: var(--ink-500); padding: 14px 16px; background: var(--paper-2); border-bottom: 1px solid var(--border); }
  .gk-orders tbody th, .gk-orders tbody td { padding: 15px 16px; font: 500 14px var(--font-body); color: var(--ink-900); border-bottom: 1px solid var(--border); text-align: left; }
  .gk-orders tbody tr:last-child th, .gk-orders tbody tr:last-child td { border-bottom: 0; }
  .gk-orders-total { font-family: var(--font-mono); font-weight: 600; white-space: nowrap; }
  .gk-orders-view { text-align: right; white-space: nowrap; }

  .gk-status { display: inline-block; font: 600 11.5px var(--font-mono); letter-spacing: .02em; padding: 3px 9px; border-radius: 99px; background: var(--paper-2); color: var(--navy-700); border: 1px solid var(--border); white-space: nowrap; }
  .gk-status-paid, .gk-status-fulfilled { background: rgba(47,170,106,.12); color: #1c7a49; border-color: rgba(47,170,106,.3); }
  .gk-status-pending, .gk-status-unfulfilled, .gk-status-partial, .gk-status-partially_fulfilled { background: rgba(254,197,38,.16); color: #8a6d00; border-color: rgba(254,197,38,.4); }
  .gk-status-refunded, .gk-status-voided { background: rgba(228,69,58,.1); color: var(--danger); border-color: rgba(228,69,58,.3); }

  .gk-pagination { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 24px; }
  .gk-pagination-count { font: 600 12px var(--font-mono); color: var(--ink-500); }

  .gk-acct-empty { text-align: center; padding: 44px 20px; border: 1px dashed var(--border-strong); border-radius: 12px; display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .gk-acct-empty-text { font: 600 1.05rem var(--font-body); color: var(--ink-700); margin: 0; }

  .gk-visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }

  @media (max-width: 860px) {
    .gk-acct-hero { padding: 26px 18px 30px; }
    .gk-acct-title { font-size: 2rem; }
    .gk-acct-layout { grid-template-columns: 1fr; gap: 24px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer account",
  "settings": [
    { "type": "text", "id": "greeting", "label": "Greeting", "default": "Welcome back" },
    { "type": "text", "id": "empty_text", "label": "Empty orders text", "default": "You haven't placed any orders yet." },
    { "type": "text", "id": "empty_button", "label": "Empty orders button", "default": "Shop the drop" },
    { "type": "textarea", "id": "support_note", "label": "Support note", "default": "Every purchase supports Gotham Rugby — NYC's inclusive rugby club. (Not a tax-deductible donation.)" }
  ],
  "presets": [{ "name": "Customer account" }],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
