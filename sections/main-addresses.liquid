{% comment %}
  Gotham Knights — customer addresses (classic customer accounts).
  List saved addresses with add / edit / delete via {% form 'customer_address' %}.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/customers-addresses
{% endcomment %}

<div class="gk-acct">
  <div class="gk-acct-hero full-width">
    <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-acct-hero-crest">
    <div class="gk-band-inner gk-acct-hero-inner">
      <nav class="gk-acct-crumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> /
        <a href="{{ routes.account_url }}">My account</a> /
        <span>Addresses</span>
      </nav>
      <h1 class="gk-acct-title gk-athletic">{{ section.settings.heading | default: 'Addresses' }}</h1>
      <p class="gk-acct-sub">{{ customer.addresses_count }} saved {% if customer.addresses_count == 1 %}address{% else %}addresses{% endif %}</p>
    </div>
  </div>

  <div class="gk-band gk-band-paper full-width">
    <div class="gk-band-inner gk-acct-body">

      <div class="gk-addr-top">
        <a class="gk-tlink" href="{{ routes.account_url }}">← Back to account</a>
        <button type="button" class="gk-btn gk-btn-primary gk-addr-add-btn" data-addr-toggle="new">+ Add a new address</button>
      </div>

      {% comment %} ---- New address form (hidden until toggled) ---- {% endcomment %}
      <div class="gk-addr-form-wrap" id="gk-addr-new" hidden>
        <div class="gk-acct-card">
          <h2 class="gk-acct-card-title">New address</h2>
          {% form 'customer_address', customer.new_address, novalidate: 'novalidate' %}
            {% if form.errors %}
              <div class="gk-form-errors" role="alert" tabindex="-1">
                <ul>
                  {% for field in form.errors %}
                    <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}

            <div class="gk-field-grid">
              <div class="gk-field">
                <label for="AddressFirstNameNew">First name</label>
                <input type="text" id="AddressFirstNameNew" name="address[first_name]" class="gk-input" autocomplete="given-name">
              </div>
              <div class="gk-field">
                <label for="AddressLastNameNew">Last name</label>
                <input type="text" id="AddressLastNameNew" name="address[last_name]" class="gk-input" autocomplete="family-name">
              </div>
            </div>
            <div class="gk-field">
              <label for="AddressCompanyNew">Company <span class="gk-optional">(optional)</span></label>
              <input type="text" id="AddressCompanyNew" name="address[company]" class="gk-input" autocomplete="organization">
            </div>
            <div class="gk-field">
              <label for="AddressAddress1New">Address</label>
              <input type="text" id="AddressAddress1New" name="address[address1]" class="gk-input" autocomplete="address-line1">
            </div>
            <div class="gk-field">
              <label for="AddressAddress2New">Apartment, suite, etc. <span class="gk-optional">(optional)</span></label>
              <input type="text" id="AddressAddress2New" name="address[address2]" class="gk-input" autocomplete="address-line2">
            </div>
            <div class="gk-field-grid">
              <div class="gk-field">
                <label for="AddressCityNew">City</label>
                <input type="text" id="AddressCityNew" name="address[city]" class="gk-input" autocomplete="address-level2">
              </div>
              <div class="gk-field">
                <label for="AddressZipNew">Postal / ZIP code</label>
                <input type="text" id="AddressZipNew" name="address[zip]" class="gk-input" autocomplete="postal-code" autocapitalize="characters">
              </div>
            </div>
            <div class="gk-field-grid">
              <div class="gk-field">
                <label for="AddressCountryNew">Country / region</label>
                <select id="AddressCountryNew" name="address[country]" class="gk-select" data-default="{{ customer.new_address.country }}" autocomplete="country">{{ country_option_tags }}</select>
              </div>
              <div class="gk-field" id="AddressProvinceContainerNew">
                <label for="AddressProvinceNew">State / province</label>
                <select id="AddressProvinceNew" name="address[province]" class="gk-select" data-default="{{ customer.new_address.province }}" autocomplete="address-level1"></select>
              </div>
            </div>
            <div class="gk-field">
              <label for="AddressPhoneNew">Phone <span class="gk-optional">(optional)</span></label>
              <input type="tel" id="AddressPhoneNew" name="address[phone]" class="gk-input" autocomplete="tel">
            </div>
            <label class="gk-checkbox">
              <input type="checkbox" name="address[default]" value="1">
              <span>Set as default address</span>
            </label>

            <div class="gk-addr-actions">
              <button type="submit" class="gk-btn gk-btn-primary">Save address</button>
              <button type="button" class="gk-btn gk-btn-outline-light" data-addr-toggle="new">Cancel</button>
            </div>
          {% endform %}
        </div>
      </div>

      {% comment %} ---- Existing addresses ---- {% endcomment %}
      {% paginate customer.addresses by 6 %}
        {% if customer.addresses.size > 0 %}
          <div class="gk-addr-grid">
            {% for address in customer.addresses %}
              <div class="gk-addr-card">
                {% if address == customer.default_address %}<span class="gk-badge gk-badge-gold gk-addr-default">Default</span>{% endif %}
                <address class="gk-address-block">{{ address | format_address }}</address>
                <div class="gk-addr-card-actions">
                  <button type="button" class="gk-tlink" data-addr-toggle="edit-{{ address.id }}">Edit</button>
                  <button type="button" class="gk-tlink gk-addr-delete" data-addr-url="{{ address.url }}">Delete</button>
                </div>

                <div class="gk-addr-form-wrap" id="gk-addr-edit-{{ address.id }}" hidden>
                  <div class="gk-acct-card gk-addr-edit-card">
                    <h2 class="gk-acct-card-title">Edit address</h2>
                    {% form 'customer_address', address, novalidate: 'novalidate' %}
                      <div class="gk-field-grid">
                        <div class="gk-field">
                          <label for="AddressFirstName{{ address.id }}">First name</label>
                          <input type="text" id="AddressFirstName{{ address.id }}" name="address[first_name]" class="gk-input" value="{{ address.first_name | escape }}" autocomplete="given-name">
                        </div>
                        <div class="gk-field">
                          <label for="AddressLastName{{ address.id }}">Last name</label>
                          <input type="text" id="AddressLastName{{ address.id }}" name="address[last_name]" class="gk-input" value="{{ address.last_name | escape }}" autocomplete="family-name">
                        </div>
                      </div>
                      <div class="gk-field">
                        <label for="AddressCompany{{ address.id }}">Company <span class="gk-optional">(optional)</span></label>
                        <input type="text" id="AddressCompany{{ address.id }}" name="address[company]" class="gk-input" value="{{ address.company | escape }}" autocomplete="organization">
                      </div>
                      <div class="gk-field">
                        <label for="AddressAddress1{{ address.id }}">Address</label>
                        <input type="text" id="AddressAddress1{{ address.id }}" name="address[address1]" class="gk-input" value="{{ address.address1 | escape }}" autocomplete="address-line1">
                      </div>
                      <div class="gk-field">
                        <label for="AddressAddress2{{ address.id }}">Apartment, suite, etc. <span class="gk-optional">(optional)</span></label>
                        <input type="text" id="AddressAddress2{{ address.id }}" name="address[address2]" class="gk-input" value="{{ address.address2 | escape }}" autocomplete="address-line2">
                      </div>
                      <div class="gk-field-grid">
                        <div class="gk-field">
                          <label for="AddressCity{{ address.id }}">City</label>
                          <input type="text" id="AddressCity{{ address.id }}" name="address[city]" class="gk-input" value="{{ address.city | escape }}" autocomplete="address-level2">
                        </div>
                        <div class="gk-field">
                          <label for="AddressZip{{ address.id }}">Postal / ZIP code</label>
                          <input type="text" id="AddressZip{{ address.id }}" name="address[zip]" class="gk-input" value="{{ address.zip | escape }}" autocomplete="postal-code" autocapitalize="characters">
                        </div>
                      </div>
                      <div class="gk-field-grid">
                        <div class="gk-field">
                          <label for="AddressCountry{{ address.id }}">Country / region</label>
                          <select id="AddressCountry{{ address.id }}" name="address[country]" class="gk-select" data-default="{{ address.country | escape }}" autocomplete="country">{{ country_option_tags }}</select>
                        </div>
                        <div class="gk-field" id="AddressProvinceContainer{{ address.id }}">
                          <label for="AddressProvince{{ address.id }}">State / province</label>
                          <select id="AddressProvince{{ address.id }}" name="address[province]" class="gk-select" data-default="{{ address.province | escape }}" autocomplete="address-level1"></select>
                        </div>
                      </div>
                      <div class="gk-field">
                        <label for="AddressPhone{{ address.id }}">Phone <span class="gk-optional">(optional)</span></label>
                        <input type="tel" id="AddressPhone{{ address.id }}" name="address[phone]" class="gk-input" value="{{ address.phone | escape }}" autocomplete="tel">
                      </div>
                      <label class="gk-checkbox">
                        <input type="checkbox" name="address[default]" value="1" {% if address == customer.default_address %}checked{% endif %}>
                        <span>Set as default address</span>
                      </label>

                      <div class="gk-addr-actions">
                        <button type="submit" class="gk-btn gk-btn-primary">Update address</button>
                        <button type="button" class="gk-btn gk-btn-outline-light" data-addr-toggle="edit-{{ address.id }}">Cancel</button>
                      </div>
                    {% endform %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="gk-pagination" aria-label="Address pages">
              {% if paginate.previous %}<a class="gk-tlink" href="{{ paginate.previous.url }}">← Previous</a>{% endif %}
              <span class="gk-pagination-count">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
              {% if paginate.next %}<a class="gk-tlink" href="{{ paginate.next.url }}">Next →</a>{% endif %}
            </nav>
          {% endif %}
        {% else %}
          <p class="gk-addr-none">You don't have any saved addresses yet.</p>
        {% endif %}
      {% endpaginate %}

    </div>
  </div>
</div>

<script>
  (function () {
    // Toggle any address form (new / edit) open and closed.
    document.querySelectorAll('[data-addr-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var el = document.getElementById('gk-addr-' + btn.dataset.addrToggle);
        if (el) {
          el.hidden = !el.hidden;
          if (!el.hidden) {
            var focusable = el.querySelector('input, select');
            if (focusable) focusable.focus();
          }
        }
      });
    });

    // Delete with confirmation via a POST form (_method=delete).
    document.querySelectorAll('.gk-addr-delete').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!window.confirm('Delete this address?')) return;
        var f = document.createElement('form');
        f.method = 'post';
        f.action = btn.dataset.addrUrl;
        f.style.display = 'none';
        f.innerHTML = '<input type="hidden" name="_method" value="delete">';
        document.body.appendChild(f);
        f.submit();
      });
    });

    // Country/province linkage using Shopify's helper when available.
    function initProvince(countryId, provinceId, containerId) {
      var country = document.getElementById(countryId);
      var province = document.getElementById(provinceId);
      var container = document.getElementById(containerId);
      if (!country || !province) return;
      if (window.Shopify && Shopify.CountryProvinceSelector) {
        new Shopify.CountryProvinceSelector(countryId, provinceId, { hideElement: containerId });
      } else {
        // Fallback: no province data available — accept a free-text state.
        if (container) container.hidden = false;
        var def = province.getAttribute('data-default');
        if (def) {
          var opt = document.createElement('option');
          opt.value = def; opt.textContent = def; opt.selected = true;
          province.appendChild(opt);
        }
      }
    }

    initProvince('AddressCountryNew', 'AddressProvinceNew', 'AddressProvinceContainerNew');
    {% for address in customer.addresses %}
      initProvince('AddressCountry{{ address.id }}', 'AddressProvince{{ address.id }}', 'AddressProvinceContainer{{ address.id }}');
    {% endfor %}
  })();
</script>

{% stylesheet %}
  .gk-acct-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 40px 50px 44px; }
  .gk-acct-hero-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-acct-hero-inner { position: relative; }
  .gk-acct-crumb { font: 600 12px var(--font-mono); letter-spacing: .04em; color: var(--navy-300); margin-bottom: 16px; }
  .gk-acct-crumb a { color: var(--navy-200); text-decoration: none; }
  .gk-acct-crumb span { color: var(--gold-400); }
  .gk-acct-title { color: #fff; font-size: 2.7rem; line-height: .98; margin: 0; }
  .gk-acct-sub { color: var(--navy-100); font: 500 14px var(--font-mono); margin: 14px 0 0; }

  .gk-addr-top { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 26px; }

  .gk-acct-card { background: var(--surface-card); border: 1px solid var(--border); border-radius: 14px; padding: 22px; }
  .gk-acct-card-title { font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .08em; color: var(--ink-500); margin: 0 0 16px; }
  .gk-addr-form-wrap { margin-bottom: 26px; }

  .gk-field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .gk-field { margin-bottom: 16px; }
  .gk-field label { display: block; font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .06em; color: var(--navy-700); margin-bottom: 8px; }
  .gk-optional { font-weight: 500; text-transform: none; letter-spacing: 0; color: var(--ink-400); }
  .gk-input, .gk-select { width: 100%; padding: 12px 14px; border: 1.5px solid var(--border-strong); border-radius: 8px; font: 400 15px var(--font-body); color: var(--ink-900); background: #fff; }
  .gk-input:focus, .gk-select:focus { outline: none; border-color: var(--navy-700); box-shadow: 0 0 0 3px rgba(13,29,65,.12); }
  .gk-checkbox { display: flex; align-items: center; gap: 9px; font: 500 14px var(--font-body); color: var(--ink-700); margin: 6px 0 4px; cursor: pointer; }
  .gk-checkbox input { width: 17px; height: 17px; accent-color: var(--navy-700); }
  .gk-addr-actions { display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap; }
  .gk-addr-actions .gk-btn-outline-light { color: var(--navy-700); border-color: var(--border-strong); }

  .gk-addr-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .gk-addr-card { position: relative; background: var(--surface-card); border: 1px solid var(--border); border-radius: 14px; padding: 22px; }
  .gk-addr-default { position: absolute; top: 16px; right: 16px; }
  .gk-address-block { font: 400 14.5px/1.65 var(--font-body); color: var(--ink-900); font-style: normal; }
  .gk-addr-card-actions { display: flex; gap: 18px; margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border); }
  .gk-addr-card-actions .gk-tlink { background: none; border: 0; padding: 0; cursor: pointer; font: 600 13px var(--font-body); }
  .gk-addr-delete { color: var(--danger) !important; }
  .gk-addr-edit-card { margin-top: 18px; grid-column: 1 / -1; }

  .gk-form-errors { background: rgba(228,69,58,.08); border: 1px solid var(--danger); border-radius: 8px; padding: 12px 16px; margin-bottom: 18px; }
  .gk-form-errors ul { margin: 0; padding-left: 18px; }
  .gk-form-errors li { font: 500 13.5px/1.5 var(--font-body); color: var(--danger); }

  .gk-pagination { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 28px; }
  .gk-pagination-count { font: 600 12px var(--font-mono); color: var(--ink-500); }
  .gk-addr-none { font: 500 1rem var(--font-body); color: var(--ink-500); padding: 20px 0; }

  @media (max-width: 860px) {
    .gk-acct-hero { padding: 26px 18px 30px; }
    .gk-acct-title { font-size: 2rem; }
    .gk-field-grid { grid-template-columns: 1fr; gap: 0; }
    .gk-addr-grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer addresses",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Addresses" }
  ],
  "presets": [{ "name": "Customer addresses" }],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
