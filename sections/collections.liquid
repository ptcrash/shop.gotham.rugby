{% comment %}
  Gotham Knights collections index — navy hero + a grid of collection tiles
  matching the homepage "Shop by collection" aesthetic. Collections with a
  featured image use it; the rest fall back to cycling branded pattern tiles.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<div class="gk-collections full-width">
  <div class="gk-col-hero full-width">
    <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-col-hero-crest">
    <div class="gk-band-inner gk-col-hero-inner">
      <nav class="gk-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> / <span>Collections</span>
      </nav>
      <h1 class="gk-col-title gk-athletic">{{ section.settings.heading | default: 'Collections' }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="gk-col-desc">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>

  <div class="gk-band gk-band-paper full-width">
    <div class="gk-band-inner">
      {% for block in section.blocks %}
        {% if block.type == '@app' %}
          {% render block %}
        {% endif %}
      {% endfor %}
      <div class="gk-tiles gk-collections-grid" style="--gk-cols: {{ section.settings.columns }}">
        {% assign styles = 'dark,light,stripes,anniversary' | split: ',' %}
        {% for collection in collections %}
          {% liquid
            assign idx = forloop.index0 | modulo: 4
            assign style = styles[idx]
            if collection.featured_image
              assign tile_style = 'photo'
            else
              assign tile_style = style
            endif
          %}
          <a class="gk-ctile gk-tile-{{ tile_style }}" href="{{ collection.url }}">
            <span class="gk-ctile-img">
              {% if collection.featured_image %}
                {{ collection.featured_image | image_url: width: 600, height: 600, crop: 'center' | image_tag: loading: 'lazy', class: 'gk-ctile-photo', alt: collection.title | escape }}
              {% elsif style == 'light' %}
                <img src="{{ 'gk-shield-2c.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150">
              {% elsif style == 'anniversary' %}
                <span class="gk-anniv"><span class="gk-anniv-num">GK</span></span>
              {% else %}
                <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150">
              {% endif %}
            </span>
            <span class="gk-ctile-scrim"></span>
            <span class="gk-ctile-content">
              <span class="gk-ctile-title">{{ collection.title }}</span>
              <span class="gk-ctile-meta">
                <span class="gk-ctile-count">{{ collection.products_count }} {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
              </span>
            </span>
          </a>
        {% else %}
          <p class="gk-collections-empty">No collections yet.</p>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .gk-col-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 40px 50px 44px; }
  .gk-col-hero-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-col-hero-inner { position: relative; }
  .gk-breadcrumb { font: 600 12px var(--font-mono); letter-spacing: .04em; color: var(--navy-300); margin-bottom: 16px; }
  .gk-breadcrumb a { color: var(--navy-200); text-decoration: none; }
  .gk-breadcrumb span { color: var(--gold-400); }
  .gk-col-title { color: #fff; font-size: 3rem; line-height: .95; margin: 0; }
  .gk-col-desc { color: var(--navy-100); font-size: 1.1rem; line-height: 1.55; max-width: 60ch; margin: 14px 0 0; }
  .gk-collections-grid { grid-auto-rows: 300px; grid-template-columns: repeat(var(--gk-cols, 4), 1fr); }
  .gk-collections-empty { color: var(--ink-500); font-size: 1rem; }
  @media (max-width: 860px) {
    .gk-col-hero { padding: 26px 18px 30px; }
    .gk-col-title { font-size: 2.1rem; }
    .gk-collections-grid { grid-auto-rows: 170px; grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Every kit, sorted by squad — from Core Essentials to the 25 Years capsule." },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [{ "name": "Collections list" }],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
