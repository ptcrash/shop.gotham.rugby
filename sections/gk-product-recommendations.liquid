{% comment %}
  Gotham Knights — Shopify native Product Recommendations.
  Uses Shopify's Product Recommendations API (ML-driven "related"/"complementary"
  results). On first paint the container is empty; a small custom element fetches
  {{ routes.product_recommendations_url }}?section_id=…&product_id=… and swaps in
  the server-rendered grid. When Shopify re-renders THIS section through that
  route, recommendations.performed is true and the grid below is emitted.
  https://shopify.dev/docs/api/liquid/objects/recommendations
{% endcomment %}

{% liquid
  assign limit = section.settings.products_to_show | default: 4
  assign rec_type = section.settings.intent | default: 'related'
%}

<gk-recommendations
  class="gk-recs-wrap full-width"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent={{ rec_type }}"
>
  {% if recommendations.performed %}
    {% if recommendations.products_count > 0 %}
      <div class="gk-band gk-band-sunken full-width">
        <div class="gk-band-inner">
          <div class="gk-band-head">
            <div>
              {% if section.settings.eyebrow != blank %}
                <div class="gk-eyebrow-gold">{{ section.settings.eyebrow }}</div>
              {% endif %}
              {% if section.settings.heading != blank %}
                <h2 class="gk-band-title">{{ section.settings.heading }}</h2>
              {% endif %}
            </div>
          </div>

          {% for block in section.blocks %}
            {% if block.type == '@app' %}
              {% render block %}
            {% endif %}
          {% endfor %}

          <div class="gk-pgrid gk-recs-grid" style="--gk-card-ratio: 4/5">
            {% for rec in recommendations.products limit: limit %}
              {% render 'product-card', product: rec %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}
</gk-recommendations>

<script>
  (function () {
    if (customElements.get('gk-recommendations')) return;
    customElements.define('gk-recommendations', class extends HTMLElement {
      connectedCallback() {
        var url = this.dataset.url;
        // Only fetch when the grid has not already been rendered server-side.
        if (!url || this.querySelector('.gk-recs-grid')) return;
        var self = this;
        fetch(url)
          .then(function (res) { return res.text(); })
          .then(function (text) {
            var html = new DOMParser().parseFromString(text, 'text/html');
            var incoming = html.querySelector('gk-recommendations');
            if (incoming && incoming.innerHTML.trim().length) {
              self.innerHTML = incoming.innerHTML;
            }
          })
          .catch(function () { /* recommendations are non-critical; fail quietly */ });
      }
    });
  })();
</script>

{% stylesheet %}
  .gk-recs-wrap:empty { display: none; }
  .gk-recs-grid .gk-pcard-img,
  .gk-recs-grid .gk-pcard-standin { aspect-ratio: var(--gk-card-ratio, 4/5); }
{% endstylesheet %}

{% schema %}
{
  "name": "Product recommendations",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Dynamic ML recommendations from Shopify's Product Recommendations API. Appears on product pages only."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Complete the kit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation type",
      "default": "related",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "info": "Complementary requires the Search & Discovery app; falls back to related when unavailable."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Product recommendations" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
