{% comment %}
  Gotham Knights blog listing — navy hero, optional tag filter row, a grid of
  branded article cards, and pagination.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

{% assign per_page = section.settings.articles_per_page | default: 9 %}

<div class="gk-blog full-width">
  <div class="gk-blog-hero full-width">
    <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-blog-crest">
    <div class="gk-band-inner gk-blog-hero-inner">
      <nav class="gk-breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a> /
        <span>{{ blog.title }}</span>
      </nav>
      {% if section.settings.eyebrow != blank %}<div class="gk-eyebrow-gold gk-eyebrow-onnavy">{{ section.settings.eyebrow }}</div>{% endif %}
      <h1 class="gk-blog-title gk-athletic">{{ blog.title }}</h1>
      {% if section.settings.intro != blank %}<p class="gk-blog-intro">{{ section.settings.intro }}</p>{% endif %}
    </div>
  </div>

  {% if section.settings.show_tags and blog.all_tags.size > 0 %}
    <div class="gk-blog-tagbar full-width">
      <div class="gk-band-inner gk-blog-tagbar-inner">
        <a class="gk-blog-tag{% unless current_tags %} is-active{% endunless %}" href="{{ blog.url }}">All</a>
        {% for tag in blog.all_tags %}
          <a class="gk-blog-tag{% if current_tags contains tag %} is-active{% endif %}" href="{{ blog.url }}/tagged/{{ tag | handleize }}">{{ tag }}</a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="gk-band gk-band-paper full-width">
    <div class="gk-band-inner">
      {% if blog.articles.size > 0 %}
        {% paginate blog.articles by per_page %}
          <div class="gk-blog-grid gk-blog-grid--{{ section.settings.layout }}">
            {% for article in blog.articles %}
              <a class="gk-acard" href="{{ article.url }}">
                <div class="gk-acard-media">
                  {% if article.image %}
                    {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', class: 'gk-acard-img', alt: article.image.alt | default: article.title | escape }}
                  {% else %}
                    <span class="gk-pcard-standin gk-standin-dark gk-acard-standin">{{ 'gk-shield-inv.svg' | inline_asset_content }}</span>
                  {% endif %}
                  {% if article.tags.size > 0 %}
                    <span class="gk-badge gk-badge-gold gk-acard-badge">{{ article.tags.first }}</span>
                  {% endif %}
                </div>
                <div class="gk-acard-body">
                  {% if section.settings.show_date or section.settings.show_author %}
                    <div class="gk-acard-meta">
                      {% if section.settings.show_date %}<time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %-d, %Y' }}</time>{% endif %}
                      {% if section.settings.show_date and section.settings.show_author %} · {% endif %}
                      {% if section.settings.show_author %}<span>{{ article.author }}</span>{% endif %}
                    </div>
                  {% endif %}
                  <h2 class="gk-acard-title">{{ article.title }}</h2>
                  {% if section.settings.show_excerpt and article.excerpt_or_content != blank %}
                    <p class="gk-acard-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 26 }}</p>
                  {% endif %}
                  <span class="gk-tlink gk-acard-link">Read story</span>
                </div>
              </a>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="gk-pagination" aria-label="Pagination">{{ paginate | default_pagination }}</nav>
          {% endif %}
        {% endpaginate %}
      {% else %}
        <p class="gk-blog-empty">No stories published yet. Check back soon.</p>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .gk-blog-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 44px 50px 48px; }
  .gk-blog-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-blog-hero-inner { position: relative; }
  .gk-blog-title { color: #fff; font-size: 3.2rem; line-height: .95; margin: 0; }
  .gk-blog-intro { color: var(--navy-100); font: 400 1.1rem/1.55 var(--font-body); max-width: 58ch; margin: 14px 0 0; }

  .gk-blog-tagbar { background: var(--paper); border-bottom: 1px solid var(--border); padding: 14px 50px; }
  .gk-blog-tagbar-inner { display: flex; gap: 9px; flex-wrap: wrap; }
  .gk-blog-tag { font: 600 13px var(--font-body); padding: 8px 15px; border: 1px solid var(--border-strong); border-radius: 99px; background: #fff; color: var(--navy-700); text-decoration: none; }
  .gk-blog-tag:hover { border-color: var(--navy-700); }
  .gk-blog-tag.is-active { background: var(--navy-700); color: #fff; border-color: var(--navy-700); }

  .gk-blog-grid { display: grid; gap: 26px; }
  .gk-blog-grid--grid { grid-template-columns: repeat(3, 1fr); }
  .gk-blog-grid--list { grid-template-columns: 1fr; max-width: 820px; margin: 0 auto; }
  .gk-blog-grid--list .gk-acard { flex-direction: row; }
  .gk-blog-grid--list .gk-acard-media { width: 40%; aspect-ratio: 4/3; flex: none; }

  .gk-acard { position: relative; display: flex; flex-direction: column; text-decoration: none; background: #fff; border: 1px solid var(--border); border-radius: var(--radius-md, 10px); overflow: hidden; transition: transform .22s var(--ease-standard), box-shadow .22s var(--ease-standard); }
  .gk-acard:hover { transform: translateY(-5px); box-shadow: 0 18px 40px rgba(7,17,42,.2); }
  .gk-acard-media { position: relative; aspect-ratio: 16/10; background: var(--paper-2); overflow: hidden; }
  .gk-acard-img { width: 100%; height: 100%; object-fit: cover; }
  .gk-acard-standin { width: 100%; height: 100%; }
  .gk-acard-standin svg { width: 40%; }
  .gk-acard-badge { top: 12px; left: 12px; }
  .gk-acard-body { padding: 18px 20px 22px; display: flex; flex-direction: column; gap: 10px; }
  .gk-acard-meta { font: 600 12px var(--font-mono); letter-spacing: .02em; color: var(--ink-500); text-transform: uppercase; }
  .gk-acard-title { margin: 0; font: 800 20px/1.15 var(--font-heading); color: var(--navy-700); letter-spacing: -.01em; }
  .gk-acard-excerpt { margin: 0; font: 400 14.5px/1.6 var(--font-body); color: var(--ink-700); }
  .gk-acard-link { align-self: flex-start; margin-top: 4px; }

  .gk-blog-empty { text-align: center; padding: 40px 0; color: var(--ink-500); font-size: 1rem; }

  .gk-pagination { display: flex; justify-content: center; gap: 8px; margin-top: 44px; font: 600 14px var(--font-mono); }
  .gk-pagination a, .gk-pagination span { color: var(--navy-500); text-decoration: none; padding: 8px 12px; border-radius: 6px; }
  .gk-pagination a:hover { background: var(--paper-2); }
  .gk-pagination .current { color: var(--navy-700); background: var(--gold-500); }

  @media (max-width: 980px) { .gk-blog-grid--grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 860px) {
    .gk-blog-hero { padding: 28px 18px 32px; }
    .gk-blog-title { font-size: 2.2rem; }
    .gk-blog-tagbar { padding: 12px 18px; }
    .gk-blog-grid--grid { grid-template-columns: 1fr; }
    .gk-blog-grid--list .gk-acard { flex-direction: column; }
    .gk-blog-grid--list .gk-acard-media { width: 100%; aspect-ratio: 16/10; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From the club" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Match reports, kit drops, and stories from Gotham Rugby." },
    { "type": "select", "id": "layout", "label": "Layout", "default": "grid", "options": [
      { "value": "grid", "label": "Grid" },
      { "value": "list", "label": "List" }
    ] },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "checkbox", "id": "show_tags", "label": "Show tag filter bar", "default": true },
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 24, "step": 3, "default": 9 }
  ]
}
{% endschema %}
