{% comment %}
  Gotham Knights password / coming-soon landing — full-height navy split with the
  crest, a headline, the storefront password form, and a newsletter signup.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<div class="gk-pw full-width">
  <div class="gk-pw-stripe" aria-hidden="true"></div>
  <div class="gk-pw-inner">
    <div class="gk-pw-brand">
      {% if settings.logo %}
        {{ settings.logo | image_url: width: 360 | image_tag: class: 'gk-pw-logo', alt: shop.name, widths: '180,240,360' }}
      {% else %}
        <img src="{{ 'gk-logo-horizontal.svg' | asset_url }}" alt="{{ shop.name | escape }}" width="260" height="70" class="gk-pw-logo">
      {% endif %}
    </div>

    {% if section.settings.eyebrow != blank %}<div class="gk-eyebrow-gold gk-eyebrow-onnavy gk-pw-eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
    <h1 class="gk-pw-title gk-athletic">{{ section.settings.heading | default: 'Kicking off soon' }}</h1>
    {% if section.settings.subheading != blank %}<p class="gk-pw-sub">{{ section.settings.subheading }}</p>{% endif %}
    {% if shop.password_message != blank %}<div class="gk-pw-message rte">{{ shop.password_message }}</div>{% endif %}

    {% if section.settings.show_newsletter %}
      <div class="gk-pw-card">
        <h2 class="gk-pw-card-title">{{ section.settings.newsletter_heading | default: 'Get on the drop list' }}</h2>
        {% if section.settings.newsletter_body != blank %}<p class="gk-pw-card-body">{{ section.settings.newsletter_body }}</p>{% endif %}
        {% form 'customer', class: 'gk-pw-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter, prelaunch">
          {% if form.posted_successfully? %}
            <p class="gk-pw-success">Thanks — you're on the list.</p>
          {% else %}
            <label for="gk-pw-email" class="gk-visually-hidden">Email address</label>
            <input type="email" id="gk-pw-email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder | default: 'you@email.com' }}" aria-label="Email address" required>
            <button type="submit" class="gk-btn gk-btn-primary gk-pw-form-btn">{{ section.settings.newsletter_button | default: 'Notify me' }}</button>
          {% endif %}
        {% endform %}
      </div>
    {% endif %}

    <div class="gk-pw-enter">
      <p class="gk-pw-enter-label">{{ section.settings.password_label | default: 'Store owner? Enter the password.' }}</p>
      {% form 'storefront_password', class: 'gk-pw-passform' %}
        {% if form.errors %}
          <div class="gk-form-errors">{{ form.errors | default_errors }}</div>
        {% endif %}
        <label for="gk-pw-password" class="gk-visually-hidden">{{ 'password.password' | t }}</label>
        <input type="password" name="password" id="gk-pw-password" placeholder="{{ 'password.password' | t }}" required>
        <button type="submit" class="gk-btn gk-btn-outline-light gk-pw-passbtn">{{ 'password.enter' | t }}</button>
      {% endform %}
    </div>

    <p class="gk-pw-foot">Powered by Shopify · {{ shop.name }}</p>
  </div>
</div>

{% stylesheet %}
  .gk-password-body { margin: 0; }
  .gk-pw { position: relative; min-height: 100vh; min-height: 100dvh; background: var(--navy-700); overflow: hidden; display: grid; place-items: center; padding: 48px 24px; }
  .gk-pw-stripe { position: absolute; inset: 0; opacity: .5; pointer-events: none;
    background: repeating-linear-gradient(-45deg, var(--navy-800) 0 22px, var(--navy-700) 22px 44px); }
  .gk-pw-inner { position: relative; width: 100%; max-width: 560px; text-align: center; }
  .gk-pw-brand { margin-bottom: 34px; }
  .gk-pw-logo { height: auto; max-width: 260px; width: 100%; display: inline-block; }
  .gk-pw-eyebrow { margin-bottom: 12px; }
  .gk-pw-title { color: #fff; font-size: 3.4rem; line-height: .95; margin: 0 0 14px; }
  .gk-pw-sub { color: var(--navy-100); font: 400 1.15rem/1.55 var(--font-body); max-width: 44ch; margin: 0 auto 8px; }
  .gk-pw-message { color: var(--navy-200); font: 400 1rem/1.55 var(--font-body); max-width: 44ch; margin: 12px auto 0; }
  .gk-pw-message a { color: var(--gold-400); }

  .gk-pw-card { background: var(--navy-800); border: 1px solid rgba(255,255,255,.12); border-radius: 14px; padding: 26px 26px 28px; margin: 32px auto 0; max-width: 460px; text-align: left; }
  .gk-pw-card-title { color: #fff; font: 800 1.15rem var(--font-heading); margin: 0 0 6px; }
  .gk-pw-card-body { color: var(--navy-200); font: 400 14px/1.5 var(--font-body); margin: 0 0 16px; }
  .gk-pw-form { display: flex; gap: 10px; flex-wrap: wrap; margin: 0; }
  .gk-pw-form input[type="email"] {
    flex: 1; min-width: 180px; font: 500 15px var(--font-body); padding: 14px 16px;
    border: 2px solid rgba(255,255,255,.28); border-radius: 6px; background: var(--navy-700); color: #fff; outline: none;
  }
  .gk-pw-form input::placeholder { color: var(--navy-300); }
  .gk-pw-form-btn { font-size: 13px; padding: 14px 22px; }
  .gk-pw-success { color: var(--gold-400); font: 700 15px var(--font-body); margin: 0; }

  .gk-pw-enter { margin: 34px auto 0; max-width: 460px; text-align: center; }
  .gk-pw-enter-label { font: 700 11px var(--font-body); text-transform: uppercase; letter-spacing: .1em; color: var(--navy-300); margin: 0 0 12px; }
  .gk-pw-passform { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin: 0; }
  .gk-pw-passform input[type="password"] {
    flex: 1; min-width: 180px; font: 500 15px var(--font-body); padding: 13px 16px;
    border: 2px solid rgba(255,255,255,.28); border-radius: 6px; background: var(--navy-800); color: #fff; outline: none;
  }
  .gk-pw-passform input::placeholder { color: var(--navy-300); }
  .gk-pw-passbtn { font-size: 13px; padding: 13px 22px; }
  .gk-form-errors { flex: 1 0 100%; color: var(--gold-400); font: 600 13px var(--font-body); margin-bottom: 4px; }

  .gk-pw-foot { color: var(--navy-400); font: 600 11px var(--font-mono); letter-spacing: .06em; margin: 40px 0 0; }

  @media (max-width: 620px) {
    .gk-pw-title { font-size: 2.4rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Gotham Rugby" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kicking off soon" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "The Gotham Knights shop is warming up. Kit, gear, and the 25 Years capsule are almost here." },
    { "type": "text", "id": "password_label", "label": "Password prompt label", "default": "Store owner? Enter the password." },
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show newsletter signup", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Get on the drop list" },
    { "type": "textarea", "id": "newsletter_body", "label": "Newsletter body", "default": "Be first to know when we launch. No spam, just the good stuff." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email placeholder", "default": "you@email.com" },
    { "type": "text", "id": "newsletter_button", "label": "Button label", "default": "Notify me" }
  ]
}
{% endschema %}
