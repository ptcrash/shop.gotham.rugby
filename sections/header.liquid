{% comment %}
  Gotham Knights storefront header — announcement bar + navy nav with gold
  underline, logo lockup, primary menu, search/account/cart icons.
  Ported from the "StoreHeader" component of the Gotham Storefront design.
{% endcomment %}

{% liquid
  assign logo = 'gk-shield-inv.svg'
  assign cart_count = cart.item_count
%}

<div class="gk-header full-width">
  {% if section.settings.announcement != blank %}
    <div class="gk-announce">{{ section.settings.announcement }}</div>
  {% endif %}

  <header class="gk-nav">
    <a href="{{ routes.root_url }}" class="gk-brand" aria-label="{{ shop.name }}">
      {{ logo | inline_asset_content }}
      <span class="gk-brand-lockup">
        <span class="gk-brand-name">{{ section.settings.wordmark | default: shop.name }}</span>
        {% if section.settings.tagline != blank %}
          <span class="gk-brand-tag">{{ section.settings.tagline }}</span>
        {% endif %}
      </span>
    </a>

    <nav class="gk-nav-links" aria-label="Primary">
      {% for link in section.settings.menu.links %}
        <a class="gk-navlink{% if link.active or link.child_active %} is-active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="gk-nav-actions">
      <a class="gk-iconbtn" href="{{ routes.search_url }}" aria-label="Search">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.35-4.35"></path></svg>
      </a>
      {% if shop.customer_accounts_enabled %}
        <a class="gk-iconbtn" href="{{ routes.account_url }}" aria-label="Account">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      {% endif %}
      <a class="gk-iconbtn gk-cart" href="{{ routes.cart_url }}" aria-label="Cart, {{ cart_count }} items">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        {% if cart_count > 0 %}<span class="gk-cart-count">{{ cart_count }}</span>{% endif %}
      </a>
    </div>
  </header>
</div>

{% stylesheet %}
  .gk-header { font-family: var(--font-body); }
  .gk-announce {
    background: var(--navy-800); color: var(--gold-400); text-align: center;
    padding: 9px 16px; font: 700 11px var(--font-body);
    letter-spacing: .14em; text-transform: uppercase;
  }
  .gk-nav {
    display: flex; align-items: center; justify-content: space-between; gap: 18px;
    padding: 14px 28px; background: var(--navy-700);
    border-bottom: 2px solid var(--gold-500);
  }
  .gk-brand { display: flex; align-items: center; gap: 11px; text-decoration: none; flex: none; }
  .gk-brand svg { height: 36px; width: auto; display: block; }
  .gk-brand-lockup { display: flex; flex-direction: column; line-height: 1; }
  .gk-brand-name {
    font-family: var(--font-wordmark); color: #fff; font-size: 19px;
    letter-spacing: -.05em; text-transform: uppercase;
  }
  .gk-brand-tag {
    font: 700 9px var(--font-body); letter-spacing: .28em; text-transform: uppercase;
    color: var(--gold-400); margin-top: 3px;
  }
  .gk-nav-links { display: flex; align-items: center; gap: 2px; }
  .gk-navlink {
    font: 700 12.5px var(--font-body); text-transform: uppercase; letter-spacing: .09em;
    color: rgba(255,255,255,.82); padding: 9px 14px; border-radius: 6px;
    text-decoration: none; transition: color var(--dur-fast) var(--ease-standard);
  }
  .gk-navlink.is-active { color: var(--gold-500); }
  .gk-nav-actions { display: flex; align-items: center; gap: 4px; color: #fff; }
  .gk-iconbtn {
    position: relative; display: grid; place-items: center; width: 38px; height: 38px;
    background: transparent; border: 0; color: #fff; cursor: pointer;
    border-radius: 8px; text-decoration: none;
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .gk-iconbtn:hover { background: rgba(255,255,255,.12); }
  .gk-cart-count {
    position: absolute; top: 3px; right: 1px; min-width: 16px; height: 16px;
    background: var(--gold-500); color: var(--navy-700); font: 800 10px var(--font-mono);
    border-radius: 99px; display: grid; place-items: center; padding: 0 4px;
  }
  @media (max-width: 860px) {
    .gk-nav { padding: 11px 15px; }
    .gk-nav-links { display: none; }
    .gk-brand svg { height: 30px; }
    .gk-brand-tag { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "announcement",
      "label": "Announcement bar",
      "default": "New drop — the 25 Years capsule · Free US shipping over $75 · Every order backs the club"
    },
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark",
      "default": "Gotham Knights"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Lockup tagline",
      "default": "The Storefront"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
