{% comment %}
  Gotham Knights collection page — navy hero with breadcrumb, a filter/sort
  toolbar, the product grid (product-card), and pagination.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

{% liquid
  assign ratio = section.settings.image_ratio
  case ratio
    when 'square'
      assign ratio_value = '1/1'
    when 'landscape'
      assign ratio_value = '4/3'
    when 'tall'
      assign ratio_value = '3/4'
    else
      assign ratio_value = '4/5'
  endcase
  assign show_toolbar = false
  if section.settings.show_filters or section.settings.show_sort
    assign show_toolbar = true
  endif
%}

<div class="gk-collection full-width">
  {% if section.settings.show_hero %}
    <div class="gk-col-hero full-width">
      <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150" class="gk-col-hero-crest">
      <div class="gk-band-inner gk-col-hero-inner">
        <nav class="gk-breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a> /
          <a href="{{ routes.collections_url }}">Collections</a> /
          <span>{{ collection.title }}</span>
        </nav>
        <h1 class="gk-col-title gk-athletic">{{ collection.title }}</h1>
        {% if section.settings.show_description and collection.description != blank %}
          <div class="gk-col-desc">{{ collection.description | strip_html | truncatewords: 40 }}</div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% paginate collection.products by section.settings.products_per_page %}
    {% if show_toolbar %}
      <div class="gk-col-toolbar full-width">
        <div class="gk-band-inner gk-toolbar-inner">
          {% if section.settings.show_filters %}
            <div class="gk-toolbar-filters">
              <span class="gk-toolbar-label">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
                Filter
              </span>
              {% for filter in collection.filters %}
                {% if filter.type == 'list' or filter.type == 'boolean' %}
                  <details class="gk-filter-pill">
                    <summary>{{ filter.label }}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
                    </summary>
                    <div class="gk-filter-menu">
                      {% for value in filter.values %}
                        <a href="{{ value.url_to_add }}" class="gk-filter-value{% if value.active %} is-active{% endif %}">{{ value.label }} ({{ value.count }})</a>
                      {% endfor %}
                    </div>
                  </details>
                {% endif %}
              {% endfor %}

              {% for filter in collection.filters %}
                {% for value in filter.active_values %}
                  <a class="gk-filter-chip" href="{{ value.url_to_remove }}">{{ value.label }}<span aria-hidden="true">×</span></a>
                {% endfor %}
              {% endfor %}
            </div>
          {% else %}
            <span></span>
          {% endif %}

          <div class="gk-toolbar-right">
            <span class="gk-toolbar-count">{{ collection.products_count }} products</span>
            {% if section.settings.show_sort %}
              <form class="gk-sort" method="get">
                {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                <label class="gk-sort-label" for="SortBy">Sort:</label>
                <select name="sort_by" id="SortBy" onchange="this.form.submit()">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
                {% for tag in current_tags %}<input type="hidden" name="tags" value="{{ tag }}">{% endfor %}
              </form>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="gk-band gk-band-paper full-width">
      <div class="gk-band-inner">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% if block.type == '@app' %}
              {% render block %}
            {% endif %}
          {% endfor %}
        {% endif %}
        {% if collection.products.size > 0 %}
          <div class="gk-pgrid gk-col-grid" style="--gk-card-ratio: {{ ratio_value }}">
            {% for product in collection.products %}
              {% render 'product-card', product: product %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="gk-loadmore">
              {% if paginate.next %}
                <a class="gk-btn gk-btn-invert" href="{{ paginate.next.url }}">Load more</a>
              {% endif %}
              <span class="gk-loadmore-count">Showing {{ collection.products.size }} of {{ collection.products_count }}</span>
            </div>
          {% endif %}
        {% else %}
          <p class="gk-col-empty">No products found. Try clearing your filters.</p>
        {% endif %}
      </div>
    </div>
  {% endpaginate %}
</div>

{% stylesheet %}
  .gk-col-hero { position: relative; background: var(--navy-700); overflow: hidden; padding: 40px 50px 44px; }
  .gk-col-hero-crest { position: absolute; top: 50%; right: -3%; transform: translateY(-50%); height: 180%; width: auto; opacity: .06; }
  .gk-col-hero-inner { position: relative; }
  .gk-breadcrumb { font: 600 12px var(--font-mono); letter-spacing: .04em; color: var(--navy-300); margin-bottom: 16px; }
  .gk-breadcrumb a { color: var(--navy-200); text-decoration: none; }
  .gk-breadcrumb span { color: var(--gold-400); }
  .gk-col-title { color: #fff; font-size: 3rem; line-height: .95; margin: 0; }
  .gk-col-desc { color: var(--navy-100); font-size: 1.1rem; line-height: 1.55; max-width: 60ch; margin: 14px 0 0; }

  .gk-col-toolbar { background: var(--paper); border-bottom: 1px solid var(--border); padding: 16px 50px; }
  .gk-toolbar-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .gk-toolbar-filters { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
  .gk-toolbar-label { display: inline-flex; align-items: center; gap: 7px; font: 700 12px var(--font-body); text-transform: uppercase; letter-spacing: .06em; color: var(--navy-700); margin-right: 4px; }
  .gk-filter-pill { position: relative; }
  .gk-filter-pill summary {
    display: inline-flex; align-items: center; gap: 7px; font: 600 13px var(--font-body);
    padding: 9px 14px; border: 1px solid var(--border-strong); border-radius: 99px;
    background: #fff; color: var(--navy-700); cursor: pointer; list-style: none;
  }
  .gk-filter-pill summary::-webkit-details-marker { display: none; }
  .gk-filter-menu {
    position: absolute; z-index: 5; margin-top: 8px; min-width: 180px; max-height: 280px; overflow: auto;
    background: #fff; border: 1px solid var(--border-strong); border-radius: 10px; padding: 8px;
    box-shadow: var(--shadow-md); display: flex; flex-direction: column; gap: 2px;
  }
  .gk-filter-value { font: 500 13px var(--font-body); color: var(--navy-700); text-decoration: none; padding: 7px 9px; border-radius: 6px; }
  .gk-filter-value:hover { background: var(--paper-2); }
  .gk-filter-value.is-active { color: var(--gold-700); font-weight: 700; }
  .gk-filter-chip {
    display: inline-flex; align-items: center; gap: 6px; font: 600 12.5px var(--font-body);
    padding: 8px 8px 8px 13px; border-radius: 99px; background: var(--navy-700); color: #fff; text-decoration: none;
  }
  .gk-filter-chip span { opacity: .7; font-size: 15px; padding: 0 3px; }
  .gk-toolbar-right { display: flex; align-items: center; gap: 16px; }
  .gk-toolbar-count { font: 600 13px var(--font-mono); color: var(--ink-500); white-space: nowrap; }
  .gk-sort { display: flex; align-items: center; gap: 8px; margin: 0; }
  .gk-sort-label { font: 600 13px var(--font-body); color: var(--navy-700); }
  .gk-sort select {
    font: 600 13px var(--font-body); padding: 9px 15px; border: 1px solid var(--border-strong);
    border-radius: 6px; background: #fff; color: var(--navy-700); cursor: pointer;
  }

  .gk-col-grid .gk-pcard-img,
  .gk-col-grid .gk-pcard-standin { aspect-ratio: var(--gk-card-ratio, 4/5); }

  .gk-loadmore { display: flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 44px; }
  .gk-loadmore-count { font: 600 12px var(--font-mono); color: var(--ink-500); }
  .gk-col-empty { text-align: center; padding: 40px 0; color: var(--ink-500); font-size: 1rem; }

  @media (max-width: 860px) {
    .gk-col-hero { padding: 26px 18px 30px; }
    .gk-col-title { font-size: 2.1rem; }
    .gk-col-toolbar { padding: 12px 18px; }
    .gk-toolbar-right { width: 100%; justify-content: space-between; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection page",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 8
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Product image ratio",
      "default": "portrait",
      "options": [
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "tall", "label": "Tall (3:4)" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ]
    },
    {
      "type": "header",
      "content": "Elements"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show collection hero",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description in hero",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort dropdown",
      "default": true
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Collection page" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
