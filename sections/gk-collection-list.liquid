{% comment %}
  Gotham Knights homepage "Shop by collection" — a row of collection tiles,
  each with a branded pattern stand-in (or the collection image when set).
{% endcomment %}

<section class="gk-band gk-band-paper full-width">
  <div class="gk-band-inner">
    <div class="gk-band-head">
      <div>
        {% if section.settings.eyebrow != blank %}<div class="gk-eyebrow-gold">{{ section.settings.eyebrow }}</div>{% endif %}
        <h2 class="gk-band-title">{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.link_label != blank %}
        <a class="gk-tlink" href="{{ section.settings.link_url | default: routes.collections_url }}">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>

    <div class="gk-tiles">
      {% for block in section.blocks %}
        {% liquid
          assign col = block.settings.collection
          assign tile_url = block.settings.collection.url | default: block.settings.url | default: routes.collections_url
          assign tile_title = block.settings.title | default: col.title
          assign tile_count = block.settings.count
          if tile_count == blank and col != blank
            assign tile_count = col.products_count | append: ' pieces'
          endif
        %}
        <a class="gk-ctile gk-tile-{{ block.settings.style }}" href="{{ tile_url }}" {{ block.shopify_attributes }}>
          <span class="gk-ctile-img">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gk-ctile-photo', alt: tile_title | escape }}
            {% elsif block.settings.style == 'light' %}
              <img src="{{ 'gk-shield-2c.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150">
            {% elsif block.settings.style == 'anniversary' %}
              <span class="gk-anniv"><span class="gk-anniv-num">25</span><span class="gk-anniv-word">Years</span></span>
            {% else %}
              <img src="{{ 'gk-shield-inv.svg' | asset_url }}" alt="" aria-hidden="true" width="150" height="150">
            {% endif %}
          </span>
          <span class="gk-ctile-scrim"></span>
          <span class="gk-ctile-content">
            <span class="gk-ctile-title">{{ tile_title }}</span>
            <span class="gk-ctile-meta">
              <span class="gk-ctile-count">{{ tile_count }}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </span>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% comment %} Tile styles (.gk-tiles / .gk-ctile / .gk-tile-*) live in gotham-ds.css (shared). {% endcomment %}

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your kit" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "View all" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection tile",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "text", "id": "count", "label": "Count label override" },
        { "type": "url", "id": "url", "label": "Link override" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        {
          "type": "select", "id": "style", "label": "Stand-in style", "default": "dark",
          "options": [
            { "value": "dark", "label": "Dark dots" },
            { "value": "light", "label": "Light dots" },
            { "value": "stripes", "label": "Stripes" },
            { "value": "anniversary", "label": "Anniversary 25" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "Collection list",
    "blocks": [
      { "type": "tile", "settings": { "title": "Core Essentials", "count": "12 pieces", "style": "dark" } },
      { "type": "tile", "settings": { "title": "Fan & Family", "count": "8 pieces", "style": "light" } },
      { "type": "tile", "settings": { "title": "Accessories", "count": "9 pieces", "style": "stripes" } },
      { "type": "tile", "settings": { "title": "Vintage · 25th", "count": "6 pieces", "style": "anniversary" } }
    ]
  }],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
